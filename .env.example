# =============================================================================
# Edvolve Backend — Secure Configuration Template
# Copy to .env and fill in your values. NEVER commit .env to version control.
# =============================================================================

# --- Database ---
# PostgreSQL (local)
# DATABASE_URL=postgresql://<username>:<password>@localhost:5432/edvolve

# PostgreSQL (NeonDB — serverless, recommended)
# Get your connection string from https://console.neon.tech
DATABASE_URL=postgresql://neondb_owner:npg_P4WHhbdtSj1G@ep-falling-water-at0ul5cp-pooler.c-9.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# --- Server ---
PORT=8001
NODE_ENV=production

# --- Authentication ---
# Generate with: openssl rand -hex 64
JWT_SECRET=replace_with_openssl_rand_hex_64
JWT_EXPIRES_IN=7d

# Admin emails (comma-separated). Users registering with these emails
# will automatically get admin/master_admin roles.
ADMIN_EMAILS=admin@example.com
MASTER_ADMIN_EMAILS=master@example.com

# Frontend URL for CORS and password reset links
CLIENT_URL=https://edvolve-seven.vercel.app
FRONTEND_URL=${CLIENT_URL}
PASSWORD_RESET_BASE_URL=${CLIENT_URL}

# --- AI Provider ---
# Options: nvidia, groq, openai, gemini
AI_PROVIDER=nvidia

# NVIDIA NIM
NVIDIA_NIM_API_KEY=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
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_MODEL=minimaxai/minimax-m2.7

# Groq (used for transcription and interview evaluation)
GROQ_API_KEY=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

# Gemini
GEMINI_API_KEY=AIzaSyA1Yu5UJ4VQ4ya_HiqghvvU2wlyywTpDE8

# AI configuration
AI_USE_RESPONSE_FORMAT=false
AI_DEFAULT_GENERATION_MODE=fast
AI_BATCH_SIZE=5
AI_BATCH_CONCURRENCY=2
AI_TIMEOUT_MS=120000
AI_FILE_CONTEXT_CHARS=5000

# --- Email (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_STARTTLS=true
SMTP_USER=noreply.edvolve@gmail.com
SMTP_PASS=oubgbevkarbkgvvd
SMTP_FROM="Edvolve <noreply.edvolve@gmail.com>"

# --- Code Runner ---
# Provider: judge0 (recommended) or local (unsafe, development only)
CODE_RUNNER_PROVIDER=judge0

# Judge0 API
JUDGE0_BASE_URL=http://localhost:2358
JUDGE0_API_KEY=your-judge0-auth-token
JUDGE0_AUTH_HEADER=X-Auth-Token
JUDGE0_REQUEST_TIMEOUT_MS=30000
JUDGE0_REQUEST_RETRIES=2
JUDGE0_CONCURRENCY=2
JUDGE0_POLL_INTERVAL_MS=1000
JUDGE0_POLL_ATTEMPTS=30

# --- Vercel Blob (for video uploads) ---
BLOB_READ_WRITE_TOKEN=vercel_blob_token
