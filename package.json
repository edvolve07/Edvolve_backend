{
  "name": "edvolve-backend-node",
  "version": "1.0.0",
  "description": "Node.js backend for the Edvolve AI interview system.",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "seed:programming": "node src/programming/seed/seedProblems.js",
