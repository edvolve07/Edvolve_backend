    "helmet": "^8.0.0",
    "helmet-csp": "^4.0.0",
    "jsonwebtoken": "^9.0.2",
    "livekit-server-sdk": "^2.15.5",
    "mammoth": "^1.8.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.104.0",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.15.2",
    "pg": "^8.22.0",
